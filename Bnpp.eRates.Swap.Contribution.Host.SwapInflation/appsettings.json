{
  "Product": {
    "Id": "SwapInflation",
    "InstanceEnvVar": "ERATESWEB_LDN_DEV_HOST_SWAP_INFLATION",
    "Endpoint": "SwapInflation",
    "EndpointType": "SwapInflationContribution",
    "DefaultTier": "T1",
    "ThrottleDelay": 1.0,
    "Policies": {
      "Read": "swap_inflation_read",
      "Write": "swap_inflation_write"
    },
    "Capabilities": [
      "QuoteOnOff",
      "AdjustAskMidSpread",
      "AdjustAskQuantity",
      "AdjustBidQuantity",
      "AdjustVwapAskSpread",
      "AdjustVwapBidSpread",
      "AdjustVwapAskSize",
      "AdjustVwapBidSize",
      "SwitchQuotingSource"
    ],
    "Feeds": {
      "Contributions": [
        { "ConnectionKey": "SwapInflationContributionsTweb" },
        { "ConnectionKey": "SwapInflationContributionsTwebGbp" },
        { "ConnectionKey": "SwapInflationContributionsBbgBpgb" },
        { "ConnectionKey": "SwapInflationContributionsBbgBpsx" }
      ],
      "Instruments": {
        "ConnectionKey": "SwapInflationInstruments"
      }
    },
    "SignalR": {
      "EventContributionUpdate": "onContributionUpdate",
      "EventNotification": "onNotification"
    }
  }
}
